    "Choose how Plainize Clip rewrites copied text.": {
      "comment": "Short explanatory subtitle in preferences. Keep the app name untranslated. Draft non-English translation; native-speaker review recommended.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "اختر كيف يعيد Plainize Clip كتابة النص المنسوخ."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Zvolte, jak Plainize Clip přepíše zkopírovaný text."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Vælg, hvordan Plainize Clip omskriver kopieret tekst."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Wählen Sie, wie Plainize Clip kopierten Text umschreibt."
          }
        },
